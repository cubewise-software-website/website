{
  "name": "cubewise-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:static": "node scripts/build-static.js",
    "preview": "node scripts/preview.js && npx serve dist",
    "serve": "npx serve dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mobile": "playwright test",
    "translate": "node scripts/translate.js",
    "extract-strings": "node scripts/extract-strings.js",
    "translate:fr": "node scripts/translate.js --locale fr",
    "translate:de": "node scripts/translate.js --locale de",
    "translate:zh-hans": "node scripts/translate.js --locale zh-hans",
    "translate:all": "npm run translate:fr && npm run translate:de && npm run translate:zh-hans"
  },
  "dependencies": {
    "cheerio": "1.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.3.1",
    "vitest": "^4.1.2"
  }
}
